# Pin que usarás para entrar a /ceo
CEO_PIN=changeme

# String random para firmar la cookie de sesión del panel de creador.
# Genera uno con: openssl rand -hex 32
SESSION_SECRET=changeme

# String random para firmar la cookie de sesión de las CUENTAS de usuario
# (registro/login normal, distinto del PIN de /ceo). Genera otro con:
# openssl rand -hex 32 — usa uno DIFERENTE al de SESSION_SECRET.
USER_SESSION_SECRET=changeme

# Connection string de Neon (console.neon.tech > tu proyecto > Connection Details).
# Usa la que dice "pooled connection" / con -pooler en el host.
DATABASE_URL=postgres://usuario:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
